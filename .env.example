# Database
# For local dev: SQLite → file:./prisma/dev.db
# For production: PostgreSQL → postgresql://user:password@host:5432/rallyiq
DATABASE_URL="file:./prisma/dev.db"

# NextAuth
# Generate a secret: openssl rand -base64 32
NEXTAUTH_SECRET="your-secret-here"
NEXTAUTH_URL="http://localhost:3000"

# OAuth Providers (optional)
# GOOGLE_CLIENT_ID=""
# GOOGLE_CLIENT_SECRET=""

# Integrations (optional)
# GAMECHANGER_API_KEY=""
# NCS_API_KEY=""
# BAND_API_KEY=""

# File Storage (optional — for video/photo uploads)
# AWS_ACCESS_KEY_ID=""
# AWS_SECRET_ACCESS_KEY=""
# AWS_S3_BUCKET=""
# AWS_REGION=""

# Email (optional — for parent comms / notifications)
# SMTP_HOST=""
# SMTP_PORT=""
# SMTP_USER=""
# SMTP_PASS=""
